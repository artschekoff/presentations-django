DJANGO_SECRET_KEY=django-insecure-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=presentations
DJANGO_DB_USER=presentations
DJANGO_DB_PASSWORD=presentations
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CHANNEL_REDIS_URL=redis://localhost:6379/1

PRESENTATIONS_DIR=
PRESENTATIONS_MAX_TABS=10
PRESENTATIONS_HEADLESS=true
PRESENTATIONS_GENERATION_TIMEOUT_MS=1200000
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000
SITE_THROTTLE_DELAY_MS=
SAVE_SCREENSHOTS=false
SAVE_LOGS=false
PRESENTATIONS_DISPATCH_INTERVAL_S=60
PRESENTATIONS_LEASE_TIMEOUT_S=1800

SOKRATIC_USERNAME=
SOKRATIC_PASSWORD=

S3_BUCKET=
S3_PREFIX=
S3_REGION=
S3_ENDPOINT_URL=
S3_VERIFY_SSL=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# auto | s3 | sftp | local — auto: SFTP_HOST set → sftp, else S3_BUCKET → s3, else local
STORAGE_BACKEND=auto
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=
SFTP_BASE_PATH=/
SFTP_KNOWN_HOSTS=

# Post-processing (defaults: enabled)
PRESENTATIONS_ZIP_OUTPUT=true
PRESENTATIONS_ZIP_DELETE_ORIGINALS=true
PRESENTATIONS_PDF_GS_COMPRESS=true

# Appears in app logs as [hostname] or [hostname/WORKER_NODE_ID]
WORKER_NODE_ID=

# Hourly stats to Telegram (set token + chat id; optional TELEGRAM_HOURLY_STATS_ENABLED=false to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_STATS_CHAT_ID=
TELEGRAM_HOURLY_STATS_ENABLED=true
